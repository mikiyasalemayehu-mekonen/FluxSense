# .env.example

# Postgres / PostGIS
POSTGRES_USER=fluxsense
POSTGRES_PASSWORD=fluxsense
POSTGRES_DB=fluxsense
DATABASE_URL=postgresql://fluxsense:fluxsense@db:5432/fluxsense

# Redis
REDIS_URL=redis://redis:6379

# Copernicus Sentinel Hub
SENTINEL_CLIENT_ID=your_client_id_here
SENTINEL_CLIENT_SECRET=your_client_secret_here

# NASA FIRMS
FIRMS_API_KEY=your_key_here

# OpenWeatherMap
OWM_API_KEY=your_key_here

# USGS (no key needed for most endpoints)
USGS_BASE_URL=https://waterservices.usgs.gov/nwis